  "formulas": {
    "Viete_Product_for_Cos": {
      "latex": "V_{\\cos}(z) = \\left|\\prod_{n=2}^{z} \\cos\\left(\\frac{\\pi z}{2^n}\\right)\\right|^{-m}",
      "description": "Vi\u00c3\u00a8te product using cosine with powers of 2",
      "category": "Vi\u00e8te Products"
    },
    "Viete_Product_for_Sin": {
      "latex": "V_{\\sin}(z) = \\left|\\prod_{n=2}^{z} \\sin\\left(\\frac{\\pi z}{2^n}\\right)\\right|^{-m}",
      "description": "Vi\u00c3\u00a8te product using sine with powers of 2",
      "category": "Vi\u00e8te Products"
    },
    "Viete_Product_for_Tan": {
      "latex": "V_{\\tan}(z) = \\left|\\prod_{n=2}^{z} \\tan\\left(\\frac{\\pi z}{2^n}\\right)\\right|^{-m}",
      "description": "Vi\u00c3\u00a8te product using tangent with powers of 2",
      "category": "Vi\u00e8te Products"
    },
    "Custom_Viete_Product_for_Cos": {
      "latex": "V_{\\cos}^{*}(z) = \\left|\\prod_{n=2}^{z} \\cos\\left(\\frac{\\pi z}{2^n \\alpha}\\right)\\right|^{-m}",
      "description": "Custom Viete product with cosine and scaling parameter",
      "category": "Vi\u00e8te Products"
    },
    "Log_power_base_Viete_Product_for_Sin": {
      "latex": "V_{\\sin}^{\\log}(z) = \\left|\\prod_{n=2}^{z} \\sin\\left(\\frac{\\pi z \\log(n)}{2^n}\\right)\\right|^{-m}",
      "description": "Logarithmic power base Viete product with sine",
      "category": "Vi\u00e8te Products"
    },
    "Half_Base_Viete_Product_for_Sin": {
      "latex": "V_{1/2}(z) = \\left|\\prod_{n=2}^{z} \\sin\\left(\\frac{\\pi z}{2^{-n}}\\right)\\right|^{-m}",
      "description": "Vi\u00c3\u00a8te product using sine with negative powers of 2",
      "category": "Vi\u00e8te Products"
    }
  },
