    "Nested_roots_product_for_2": {
      "latex": "N_2(z) = \\left|\\prod_{n=2}^{z} \\sqrt[n]{2z}\\right|^{-m}",
      "description": "Nested roots product for base 2",
      "category": "Special Functions"
    },
    "product_factory": {
      "latex": "P_{\\text{factory}}(z) = \\left|\\prod_{n=2}^{z} \\left[\\pi z \\prod_{k=2}^{z} \\left(1 - \\frac{z^2}{k^2 n^2}\\right)\\right]\\right|^{-m}",
