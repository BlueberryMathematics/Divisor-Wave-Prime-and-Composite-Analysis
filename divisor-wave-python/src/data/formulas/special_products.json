    "complex_playground_magnification_currated_functions_DEMO": {
      "latex": "D(z) = \\left|\\prod_{n=2}^{z} \\left(iz_{\\text{imag}} + iz_{\\text{imag}} \\sin(\\pi z n)\\right)^{iz_{\\text{imag}}}\\right|^{-m}",
      "description": "Complex playground function with imaginary magnification",
      "category": "Demonstration"
    },
    "Binary_Output_Prime_Indicator_Function_H": {
      "latex": "H(z) = f(z)^{g(z)}",
      "description": "Binary output prime indicator combining divisor wave functions",
      "category": "Prime Indicators"
    },
    "Prime_Output_Indicator_J": {
      "latex": "J(z) = f(z)^{f(z)^{g(z)}}",
      "description": "Prime output indicator with nested exponentiation",
      "category": "Prime Indicators"
    },
    "BOPIF_Q_Alternation_Series": {
      "latex": "Q(z) = \\sum_{n=2}^{z} (-1)^{H(n)} \\cdot H(n)",
      "description": "Binary Output Prime Indicator Function Q Alternation Series",
      "category": "Prime Indicators"
    },
    "Dirichlet_Eta_Derived_From_BOPIF": {
      "latex": "\\eta(z) = \\sum_{n=1}^{\\infty} \\frac{(-1)^{n+1} \\cdot H(n)}{n^z}",
      "description": "Dirichlet Eta function derived from Binary Output Prime Indicator",
      "category": "Prime Indicators"
    },
    "abs_loggamma": {
